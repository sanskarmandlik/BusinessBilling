PORT=5000

# --- LOCAL DEVELOPMENT (individual vars) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=family_business_db

# --- CLOUD DEPLOYMENT (overrides above, use this on Render/Railway/Neon) ---
